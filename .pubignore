# A .pubignore file works exactly like a .gitignore file, but specifically for the pub.dev registry.
# It prevents files tracked by git from being included in the final published dart package payload.

# --- Infrastructure ---
.github/

# --- Tools and Configs ---
.vscode/
.idea/

# --- Testing ---
# (While tests are useful in your repo, they aren't strictly required for downstream package consumers, reducing download size)
test/

# --- Unnecessary Lib Stuff ---
# If you have specific files inside `lib/` (like internal mock data, random dev scripts, or anything consumers shouldn't see),
# you can list them individually or by directory here:
# lib/src/testing_mocks/
# lib/dummy_data.dart
